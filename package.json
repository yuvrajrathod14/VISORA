{
  "name": "visora",
  "private": true,
  "version": "0.1.0",
  "description": "Visora by Visionatrixx — The Visual Context Engine for AI Coding",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter visora-demo dev",
    "dev:next": "pnpm --filter demo-next dev",
    "dev:vue": "pnpm --filter demo-vue dev",
    "dev:demo": "pnpm --filter visora-demo dev",
    "build": "pnpm -r build",
    "mcp": "node packages/mcp-server/dist/index.js",
    "visora": "node packages/patcher/dist/index.js",
    "hook": "node scripts/hook.js"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "unrs-resolver"
    ]
  },
  "keywords": [
    "visora",
    "ai",
    "visual-editing",
    "mcp",
    "react",
    "vite"
  ],
  "author": "Visionatrixx",
  "license": "MIT",
  "dependencies": {
    "jsdom": "^29.1.1"
  }
}
