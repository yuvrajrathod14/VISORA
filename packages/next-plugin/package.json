{
  "name": "@visora/next-plugin",
  "version": "1.0.0",
  "description": "Next.js integration for Visora",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build:overlay": "node build.js",
