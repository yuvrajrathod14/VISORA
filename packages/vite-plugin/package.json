{
  "name": "visora-vite-plugin",
  "version": "0.1.2",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && npm run build:overlay",
    "build:overlay": "esbuild src/overlay.ts --bundle --outfile=dist/overlay.js --format=iife --target=es2020 --minify",
    "dev": "tsc --watch & npm run build:overlay -- --watch"
  },
  "dependencies": {
    "visora-shared": "workspace:*"
  },
  "peerDependencies": {
    "vite": "^5.0.0 || ^6.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vite": "^5.4.11",
    "html-to-image": "^1.11.11",
    "esbuild": "^0.21.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
